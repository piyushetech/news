NODE_ENV=development
PORT=5001
MONGODB_URI=mongodb://localhost:27017/inshort
JWT_SECRET=change-this-jwt-secret-in-production
JWT_EXPIRES_IN=7d

# Google OAuth (Web client ID — used to verify mobile tokens)
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Admin dashboard login
ADMIN_EMAIL=admin@inshort.com
ADMIN_PASSWORD=Admin@123456

# Firebase FCM (optional — leave blank to skip push)
SMTP_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

ADMIN_URL=http://localhost:5174
WEB_URL=http://localhost:5175
CLIENT_URL=http://localhost:8081

# Python AI Service (optional — set ENABLED=true to use FastAPI scraper + enrichment)
PYTHON_SERVICE_ENABLED=false
PYTHON_SERVICE_URL=http://localhost:8000
PYTHON_INTERNAL_KEY=change-me-internal-key
PYTHON_TIMEOUT_MS=120000

# Hourly auto-scrape — new stories go to Pending (admin must approve)
CRON_ENABLED=true
CRON_SCHEDULE=0 * * * *
CRON_RUN_ON_START=false
# Extra CORS origins (comma-separated) — e.g. https://your-app.onrender.com
ALLOWED_ORIGINS=
